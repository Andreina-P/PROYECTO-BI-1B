    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Grupo etario
var grupo_etario;
if (edad &lt; 15) {
    grupo_etario = "Menor de 15 años";
} else if (edad &lt;= 24) {
    grupo_etario = "15-24";
} else if (edad &lt;= 34) {
    grupo_etario = "25-34";
} else if (edad &lt;= 44) {
    grupo_etario = "35-44";
} else if (edad &lt;= 54) {
    grupo_etario = "45-54";
} else if (edad &lt;= 64) {
    grupo_etario = "55-64";
} else {
    grupo_etario = "65 y más";
}

// Flags laborales
var empleo_flag = (empleo == "true" || empleo == "True" || empleo == "TRUE") ? 1 : 0;
var desempleo_flag = (desempleo == "true" || desempleo == "True" || desempleo == "TRUE") ? 1 : 0;</jsScript_script>
      </jsScript>
    </jsScripts>
